# ─────────────── VioletMediaPay Payment Gateway ───────────────
# Live endpoint by default. Override to https://violetmediapay.com/api/sanbox
# for sandbox testing.
VIOLET_BASE_URL=https://violetmediapay.com/api/live

# Get these from your VioletMediaPay merchant dashboard.
# Until the admin panel is built (Fase 2), these env vars are the source of truth.
VIOLET_API_KEY=
VIOLET_SECRET_KEY=

# How long a deposit invoice is valid, in seconds. Default 900 (15 minutes).
VIOLET_EXPIRE_SECONDS=900

# Strict-IP enforcement on the callback endpoint. When "true", only requests
# from VioletMediaPay's official IPs (202.155.132.37, 2001:df7:5300:9::122)
# are accepted. Default off because reverse proxies often rewrite the source IP.
VIOLET_STRICT_IP=false

# ─────────────── Application ───────────────
# Public origin where this app is reachable. Required by VioletMediaPay so it
# can build the redirect & callback URLs.
PUBLIC_BASE_URL=
